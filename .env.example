# Gemini API Configuration
# Get your API key from: https://ai.google.dev/

# For Vite (browser) - used by the web app
VITE_GEMINI_API_KEY=your_api_key_here

# For Node.js scripts - used by upload scripts (optional, falls back to VITE_GEMINI_API_KEY)
GEMINI_API_KEY=your_api_key_here

# Default RAG Store (your persistent file search store)
VITE_RAG_STORE_ID=fileSearchStores/valorant-coach-knowledge-ba-lh2oz2rm4ccl
RAG_STORE_ID=fileSearchStores/valorant-coach-knowledge-ba-lh2oz2rm4ccl
