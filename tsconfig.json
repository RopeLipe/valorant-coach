{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "@overwolf/types"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./code/*"
      ],
      "@/lib/*": [
        "./code/lib/*"
      ],
      "@/components/*": [
        "./code/components/*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}