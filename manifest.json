{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "OWNED",
    "version": "1.0.0",
    "minimum-overwolf-version": "0.257.0",
    "author": "OWNED Team",
    "author_display": "OWNED Team", 
    "icon": "icon.png",
    "icon_gray": "icon_gray.png",
    "launcher_icon": "desktop-icon.ico",
    "description": "Your personal OWNED AI Valorant coach."
  },
  "permissions": [
    "GameInfo",
    "Hotkeys",
    "Profile",
    "Microphone",
    "Streaming",
    "DesktopStreaming",
    "Clipboard",
    "FileSystem"
  ],
  "data": {
    "start_window": "background",
    "game_events": [
      21640
    ],
    "launch_events": [
      {
        "event": "GameLaunch",
        "event_data": {
          "game_ids": [
            21640
          ]
        },
        "start_minimized": true
      }
    ],
    "developer": {
      "enable_auto_refresh": true,
      "reload_delay": 1000,
      "filter": "*.html,assets/*.js,assets/*.css,manifest.json"
    },
    "windows": {
      "main": {
        "file": "overlay.html",
        "transparent": true,
        "resizable": false,
        "show_in_taskbar": false,
        "topmost": true,
        "size": {
          "width": 460,
          "height": 420
        },
        "min_size": {
          "width": 340,
          "height": 200
        }
      },
      "admin": {
        "file": "admin.html",
        "transparent": false,
        "resizable": true,
        "size": {
          "width": 1200,
          "height": 800
        }
      },
      "background": {
        "file": "background.html",
        "is_background_page": true
      },
      "desktop": {
        "file": "desktop.html",
        "transparent": true,
        "resizable": true,
        "show_in_taskbar": true,
        "size": {
          "width": 1200,
          "height": 800
        },
        "min_size": {
          "width": 900,
          "height": 600
        }
      }
    },
    "hotkeys": {
      "toggle_app": {
        "title": "Toggle Coach Overlay",
        "action-type": "custom",
        "default": "Ctrl+Alt+V",
        "game_ids": [
          21640
        ]
      },
      "voice_command": {
        "title": "Voice Command",
        "action-type": "custom",
        "default": "Ctrl+Alt+C",
        "hold": true,
        "game_ids": [
          21640
        ]
      },
      "toggle_desktop": {
        "title": "Toggle Desktop App",
        "action-type": "custom",
        "default": "Ctrl+Alt+D"
      },
      "toggle_settings": {
        "title": "Toggle Settings",
        "action-type": "custom",
        "default": "Ctrl+Alt+S",
        "game_ids": [
          21640
        ]
      }
    },
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [
        21640
      ]
    }
  }
}