{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "OWNED",
    "version": "1.0.0",
    "minimum-overwolf-version": "0.257.0",
    "author": "OWNED Team",
    "icon": "icon.png",
    "icon_gray": "icon_gray.png",
    "launcher_icon": "desktop-icon.ico",
    "description": "Your personal OWNED AI Valorant coach."
  },
  "permissions": [
    "GameInfo",
    "Hotkeys",
    "Profile",
    "Microphone",
    "Streaming",
    "DesktopStreaming",
    "Clipboard",
    "FileSystem"
  ],
  "data": {
    "start_window": "background",
    "windows": {
      "main": {
        "file": "dist/overlay.html",
        "transparent": true,
        "resizable": false,
        "show_in_taskbar": false,
        "topmost": true,
        "size": {
          "width": 460,
          "height": 420
        },
        "min_size": {
          "width": 340,
          "height": 200
        }
      },
      "admin": {
        "file": "dist/admin.html",
        "transparent": false,
        "resizable": true,
        "size": {
          "width": 1200,
          "height": 800
        }
      },
      "background": {
        "file": "dist/background.html",
        "transparent": true,
        "resizable": false,
        "show_in_taskbar": false,
        "is_background_page": true,
        "size": {
          "width": 1,
          "height": 1
        }
      },
      "desktop": {
        "file": "dist/desktop.html",
        "transparent": true,
        "resizable": true,
        "show_in_taskbar": true,
        "size": {
          "width": 1200,
          "height": 800
        },
        "min_size": {
          "width": 900,
          "height": 600
        }
      }
    },
    "hotkeys": {
      "toggle_app": {
        "title": "Toggle Coach Overlay",
        "action-type": "custom",
        "default": "Ctrl+Alt+V"
      },
      "voice_command": {
        "title": "Voice Command",
        "action-type": "custom",
        "default": "Ctrl+Alt+C",
        "hold": true
      },
      "toggle_desktop": {
        "title": "Toggle Desktop App",
        "action-type": "custom",
        "default": "Ctrl+Alt+D"
      },
      "toggle_settings": {
        "title": "Toggle Settings",
        "action-type": "custom",
        "default": "Ctrl+Alt+S"
      }
    },
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [
        21640
      ]
    }
  }
}